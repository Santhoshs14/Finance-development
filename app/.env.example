# ─────────────────────────────────────────────────────────────────────────
# WealthFlow environment variables — TEMPLATE
#
# Copy to `.env.local` and fill in real values. NEVER commit `.env.local`.
# All values below are placeholders. `NEXT_PUBLIC_*` vars are exposed to the
# browser bundle (safe for Firebase web config); everything else is server-only.
# ─────────────────────────────────────────────────────────────────────────

# ── Public Firebase web config (safe to expose in client bundle) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=          # optional (Analytics)

# ── Server-only: Firebase Admin SDK service account (REQUIRED) ──
# Settings → Service accounts → Generate new private key. Keep the literal
# "\n" sequences in the private key; the app converts them to newlines.
FIREBASE_PROJECT_ID=your-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ── Cron (required on Vercel for /api/cron/*) ──
CRON_SECRET=

# ── Sentry error monitoring (optional) ──
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=                            # CI/build-time source-map upload only
NEXT_PUBLIC_SENTRY_DSN=

# ── Web push / FCM (optional) ──
# Firebase Console → Cloud Messaging → Web Push certificates → key pair.
NEXT_PUBLIC_FCM_VAPID_KEY=

# ── WebAuthn passkeys (required for 2FA in production) ──
WEBAUTHN_RP_ID=yourdomain.com                 # exact hostname, no scheme/port
WEBAUTHN_ORIGIN=https://yourdomain.com        # comma-separated for multiple

# ── Vercel KV for distributed rate-limiting (optional; recommended on serverless) ──
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Dev only — skips Firebase auth in API routes (ignored in production) ──
DEV_AUTH_BYPASS=false
